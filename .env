# -----------------------------
# HORI Project Configuration
# -----------------------------

BACKEND_PORT=8000

# CORS
CORS_ALLOW_ORIGINS=*

# Time step minutes for segment timestamps
SEGMENT_STEP_MIN=5

# Toggle live API calls (weather + air quality)
USE_LIVE_WEATHER=true
USE_LIVE_AIR=true

# HTTP timeout for external API calls
HTTP_TIMEOUT=8

# -----------------------------
# PostgreSQL Database Settings
# -----------------------------
DATABASE_URL=postgresql+psycopg2://hori_user:hori123@localhost:5432/hori
